# ============================================
# VIESTYLE E-Commerce — Environment Variables
# ============================================

# App
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_USER=viestyle
POSTGRES_PASSWORD=viestyle_secret
POSTGRES_DB=viestyle_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://viestyle:viestyle_secret@localhost:5433/viestyle_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Gemini AI (Phase 5)
GEMINI_API_KEY=gemini_api_key_here

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
